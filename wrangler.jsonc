{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-01-03",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wove-customer-data",
      "database_id": "PLACEHOLDER_WILL_BE_CREATED_ON_DEPLOY"
    }
  ]
}